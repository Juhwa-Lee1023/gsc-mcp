{
  "name": "gsc-mcp",
  "version": "0.1.0",
  "description": "A narrow, read-only Google Search Console inspector MCP server and CLI.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Juhwa-Lee1023/gsc-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Juhwa-Lee1023/gsc-mcp/issues"
  },
  "homepage": "https://github.com/Juhwa-Lee1023/gsc-mcp#readme",
  "keywords": [
    "mcp",
    "google-search-console",
    "search-console",
    "read-only",
    "inspector",
    "cli",
    "typescript"
  ],
  "bin": {
    "gsc-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    ".env.example",
    "gsc-mcp.config.example.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "clean": "rm -rf dist .tmp coverage",
    "dev": "tsx src/cli/index.ts",
    "prepack": "pnpm build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.2",
    "luxon": "^3.7.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
