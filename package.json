{
  "name": "gsc-mcp",
  "version": "0.1.0",
  "description": "A narrow, reliable Google Search Console focused MCP server and CLI.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "gsc-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "gsc-mcp.config.example.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tmp coverage",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.2",
    "luxon": "^3.7.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
